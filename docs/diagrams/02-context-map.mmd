%% DDD Context Map - PoS Multi-Line Bounded Contexts
%% Relationships: CF = Conformist, ACL = Anti-Corruption Layer, OHS = Open Host Service, PL = Published Language

flowchart LR
    subgraph Core
        TX[Transaction]
        CAT[Catalog]
        WQ[Workflow/Queue]
    end

    subgraph Support
        IAM[Identity & Access<br/>+ Terminal]
        CUST[Customer]
        SUP[Supplier]
        ACC[Accounting]
        INV[Inventory]
        RPT[Reporting]
        SET[Settings<br/>+ SyncSettings]
        PRICE[Pricing & Promotion]
        SYNC[Sync<br/>Queue / Conflict / Engine]
    end

    TX -->|ACL / read| CAT
    TX -->|optional| CUST
    TX -->|user/session/terminal| IAM
    TX -->|price rules| PRICE
    TX -->|events| ACC
    TX -->|events| INV
    TX -->|events| WQ

    INV -->|reference| CAT
    INV -->|goods receipt| SUP
    ACC -->|journal from| TX
    ACC -->|journal from| SUP

    RPT -.->|read model| TX
    RPT -.->|read model| INV
    RPT -.->|read model| ACC

    SET -.->|config| TX
    SET -.->|config| CAT
    SET -.->|sync config| SYNC
    IAM -.->|tenant/outlet/terminal| SET
    IAM -.->|terminal registration| SYNC

    SYNC -.->|push/pull all entities| TX
    SYNC -.->|push/pull all entities| CAT
    SYNC -.->|push/pull all entities| INV
    SYNC -.->|push/pull all entities| CUST

    style TX fill:#e74c3c,color:#fff
    style CAT fill:#e74c3c,color:#fff
    style WQ fill:#e74c3c,color:#fff
    style IAM fill:#27ae60,color:#fff
    style CUST fill:#27ae60,color:#fff
    style SUP fill:#27ae60,color:#fff
    style ACC fill:#27ae60,color:#fff
    style INV fill:#27ae60,color:#fff
    style RPT fill:#27ae60,color:#fff
    style SET fill:#27ae60,color:#fff
    style PRICE fill:#27ae60,color:#fff
    style SYNC fill:#f39c12,color:#fff
